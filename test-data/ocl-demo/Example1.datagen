<?xml version="1.0" encoding="UTF-8"?>
<datagen:DataGenConfig xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:datagen="http://www.gme.org/datagen/1.0"
    name="Example1"
    version="1.0"
    locale="de">
  <classConfigs contextClass="https://dg.de/1.0#//Person" instanceCount="10" enabled="true">
    <attributeGens featureName="firstName" generatorKey="faker.person.firstName"/>
    <attributeGens featureName="lastName" generatorKey="faker.person.lastName"/>
    <attributeGens featureName="email" generatorKey="faker.internet.email"/>
    <attributeGens featureName="phone" generatorKey="faker.phone.number"/>
    <attributeGens featureName="jobTitle" generatorKey="faker.person.jobTitle"/>
    <referenceGens featureName="address" strategy="RANDOM" minCount="0" maxCount="1"/>
    <referenceGens featureName="company" strategy="RANDOM" minCount="0" maxCount="1"/>
  </classConfigs>

</datagen:DataGenConfig>