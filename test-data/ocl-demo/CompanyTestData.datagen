<?xml version="1.0" encoding="UTF-8"?>
<datagen:DataGenConfig xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:datagen="http://www.gme.org/datagen/1.0"
    name="CompanyTestData"
    version="1.0"
    locale="de">
  <classConfigs contextClass="dge.Company" instanceCount="10" enabled="true">
    <attributeGens featureName="name" generatorKey="faker.person.fullName"/>
    <attributeGens featureName="industry" generatorKey="faker.lorem.word"/>
    <attributeGens featureName="url" generatorKey="faker.internet.url"/>
    <referenceGens featureName="address" strategy="NONE" minCount="0" maxCount="0" isContainment="true" childCount="1" maxDepth="3"/>
    <referenceGens featureName="employees" strategy="RANDOM" minCount="0" maxCount="1"/>
  </classConfigs>
  <classConfigs contextClass="dge.Address" instanceCount="10" enabled="true">
    <attributeGens featureName="street" generatorKey="faker.location.street"/>
    <attributeGens featureName="city" generatorKey="faker.location.city"/>
    <attributeGens featureName="zipCode" generatorKey="faker.location.zipCode"/>
    <attributeGens featureName="country" generatorKey="faker.location.country"/>
  </classConfigs>
  <classConfigs contextClass="dge.Person" instanceCount="10" enabled="true">
    <attributeGens featureName="firstName" generatorKey="faker.person.firstName"/>
    <attributeGens featureName="lastName" generatorKey="faker.person.lastName"/>
    <attributeGens featureName="email" generatorKey="faker.internet.email"/>
    <attributeGens featureName="phone" generatorKey="faker.phone.number"/>
    <attributeGens featureName="jobTitle" generatorKey="faker.person.jobTitle"/>
    <referenceGens featureName="address" strategy="ROUND_ROBIN" minCount="1" maxCount="1"/>
    <referenceGens featureName="company" strategy="ROUND_ROBIN" minCount="1" maxCount="1"/>
  </classConfigs>

</datagen:DataGenConfig>