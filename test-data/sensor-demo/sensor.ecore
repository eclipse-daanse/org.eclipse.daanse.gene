<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmlns:xmi="http://www.omg.org/XMI" xmi:version="2.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" nsURI="http://www.gme.org/sensor/1.0" nsPrefix="sensor" name="sensor">
  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="documentation" value="Fachmodell Sensornetzwerk. Verwaltet Sensoren mit mehreren Geometrien (Standort, Messort, Referenzflaeche) fuer orthogonale OGC-Layer-Darstellung."/>
  </eAnnotations>

  <!-- Enums -->
  <eClassifiers xsi:type="ecore:EEnum" name="Sensortyp">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Klassifikation des Sensors nach Messverfahren."/>
    </eAnnotations>
    <eLiterals name="TEMPERATUR"/>
    <eLiterals value="1" name="LUFTFEUCHTIGKEIT"/>
    <eLiterals value="2" name="FEINSTAUB"/>
    <eLiterals value="3" name="LAERM"/>
    <eLiterals value="4" name="NIEDERSCHLAG"/>
    <eLiterals value="5" name="WIND"/>
    <eLiterals value="6" name="BODENFEUCHTIGKEIT"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="Messgrund">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Grund bzw. Zweck der Messung."/>
    </eAnnotations>
    <eLiterals name="UMWELTMONITORING"/>
    <eLiterals value="1" name="VERKEHRSUEBERWACHUNG"/>
    <eLiterals value="2" name="KLIMAFORSCHUNG"/>
    <eLiterals value="3" name="LAERMSCHUTZ"/>
    <eLiterals value="4" name="IMMISSIONSSCHUTZ"/>
    <eLiterals value="5" name="GEWAESSERMONITORING"/>
  </eClassifiers>

  <!-- Wurzel: SensorNetzwerk -->
  <eClassifiers xsi:type="ecore:EClass" name="SensorNetzwerk">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Wurzelelement. Enthaelt alle Sensoren eines Netzwerks."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" lowerBound="1" eType="http://www.eclipse.org/emf/2002/Ecore#//EString" name="name">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Name des Sensornetzwerks."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" eType="http://www.eclipse.org/emf/2002/Ecore#//EString" name="betreiber">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Betreiber des Netzwerks."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" containment="true" upperBound="-1" eType="http://www.gme.org/sensor/1.0#//Sensor" name="sensoren">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Alle Sensoren des Netzwerks."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- Sensor -->
  <eClassifiers xsi:type="ecore:EClass" name="Sensor">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Ein einzelner Sensor mit Standort-, Mess- und Referenzgeometrie. Unterstuetzt orthogonale Layer-Darstellung: Jede Geometrie kann als eigener OGC-Layer visualisiert werden."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" iD="true" lowerBound="1" eType="http://www.eclipse.org/emf/2002/Ecore#//EString" name="id">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Eindeutige Sensor-ID (z.B. SEN-2025-0001)."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" lowerBound="1" eType="http://www.eclipse.org/emf/2002/Ecore#//EString" name="name">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Sprechender Name des Sensors."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" lowerBound="1" name="typ">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Typ/Messverfahren des Sensors."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" lowerBound="1" name="messgrund">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Grund bzw. Zweck der Messung."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" eType="http://www.eclipse.org/emf/2002/Ecore#//EString" name="internerHinweis">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Interner Hinweis/Kommentar zum Sensor (nicht oeffentlich)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <!-- Geometrie: Sensorstandort (Punkt) -->
    <eStructuralFeatures xsi:type="ecore:EAttribute" lowerBound="1" eType="http://www.eclipse.org/emf/2002/Ecore#//EDouble" name="geom_sensor_ort_lon">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Laengengrad des Sensorstandorts."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" lowerBound="1" eType="http://www.eclipse.org/emf/2002/Ecore#//EDouble" name="geom_sensor_ort_lat">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Breitengrad des Sensorstandorts."/>
      </eAnnotations>
    </eStructuralFeatures>

    <!-- Geometrie: Messort (Punkt) -->
    <eStructuralFeatures xsi:type="ecore:EAttribute" eType="http://www.eclipse.org/emf/2002/Ecore#//EDouble" name="geom_mess_ort_lon">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Laengengrad des Messorts (kann vom Sensorstandort abweichen)."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" eType="http://www.eclipse.org/emf/2002/Ecore#//EDouble" name="geom_mess_ort_lat">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Breitengrad des Messorts."/>
      </eAnnotations>
    </eStructuralFeatures>

    <!-- Geometrie: Referenzflaeche (Polygon - als WKT oder Koordinaten) -->
    <eStructuralFeatures xsi:type="ecore:EAttribute" eType="http://www.eclipse.org/emf/2002/Ecore#//EString" name="geom_ref_flaeche_wkt">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Referenzflaeche als WKT-Polygon (z.B. POLYGON((lon1 lat1, lon2 lat2, ...)))."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

</ecore:EPackage>