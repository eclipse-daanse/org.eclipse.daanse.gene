<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="management" nsURI="http://eclipse.org/fennec/model/atlas/management/1.0.0"
    nsPrefix="mgmt">
  <eClassifiers xsi:type="ecore:EClass" name="ObjectMetadata">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="objectId" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" iD="true"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="objectName"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="objectType" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="stage" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="scope" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="registry" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="status" lowerBound="1"
        eType="#//ObjectStatus" defaultValueLiteral="DRAFT"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="isReadOnly"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="version"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="contentHash" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="uploadUser" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="uploadTime" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="sourceChannel" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="lastChangeUser"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="lastChangeTime"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="lastChangeReason"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="reviewUser"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="reviewTime"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="reviewReason"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="complianceCheckTime"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="complianceStatus"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="governanceDocumentationId"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="generationTriggerFingerprint"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="properties" upperBound="-1"
        eType="#//StringToObjectMapEntry" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="StringToObjectMapEntry">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="key" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="value" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ObjectMetadataContainer">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="containerId" lowerBound="1"
        eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" iD="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="metadata" upperBound="-1"
        eType="#//ObjectMetadata" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="ObjectStatus">
    <eLiterals name="DRAFT" literal="DRAFT"/>
    <eLiterals name="APPROVED" value="1" literal="APPROVED"/>
    <eLiterals name="REJECTED" value="2" literal="REJECTED"/>
    <eLiterals name="DEPLOYED" value="3" literal="DEPLOYED"/>
    <eLiterals name="ARCHIVED" value="4" literal="ARCHIVED"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="PackageStatus">
    <eLiterals name="DRAFT" literal="DRAFT"/>
    <eLiterals name="APPROVED" value="1" literal="APPROVED"/>
    <eLiterals name="DEPLOYED" value="2" literal="DEPLOYED"/>
    <eLiterals name="ARCHIVED" value="3" literal="ARCHIVED"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="StorageBackendType">
    <eLiterals name="FILE"/>
    <eLiterals name="MINIO" value="1" literal="MINIO"/>
    <eLiterals name="GIT" value="2" literal="GIT"/>
    <eLiterals name="APICURIO" value="3" literal="APICURIO"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="GenerationStatus">
    <eLiterals name="REQUESTED" literal="REQUESTED"/>
    <eLiterals name="IN_PROGRESS" value="1" literal="IN_PROGRESS"/>
    <eLiterals name="COMPLETED" value="2" literal="COMPLETED"/>
    <eLiterals name="FAILED" value="3" literal="FAILED"/>
    <eLiterals name="CANCELLED" value="4" literal="CANCELLED"/>
  </eClassifiers>
</ecore:EPackage>