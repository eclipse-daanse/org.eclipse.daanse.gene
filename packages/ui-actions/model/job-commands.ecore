<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="jobcommands" nsURI="http://gene/commands/jobs/1.0.0"
    nsPrefix="jobcommands">

  <eClassifiers xsi:type="ecore:EClass" name="JobCommands"
      eSuperTypes="command-model.ecore#//CommandInterface">

    <eOperations name="cancelJob">
      <eAnnotations source="http://gene/model/command/Command">
        <details key="commandId" value="jobs.cancelJob"/>
        <details key="label" value="Cancel Job"/>
        <details key="category" value="TOOLS"/>
        <details key="scope" value="GLOBAL"/>
        <details key="icon" value="pi pi-times"/>
      </eAnnotations>
      <eParameters name="jobId" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" lowerBound="1"/>
    </eOperations>

    <eOperations name="clearCompletedJobs">
      <eAnnotations source="http://gene/model/command/Command">
        <details key="commandId" value="jobs.clearCompletedJobs"/>
        <details key="label" value="Clear Completed Jobs"/>
        <details key="category" value="TOOLS"/>
        <details key="scope" value="GLOBAL"/>
        <details key="icon" value="pi pi-eraser"/>
      </eAnnotations>
    </eOperations>

    <eOperations name="showJobsPanel">
      <eAnnotations source="http://gene/model/command/Command">
        <details key="commandId" value="jobs.showJobsPanel"/>
        <details key="label" value="Show Jobs Panel"/>
        <details key="category" value="VIEW"/>
        <details key="scope" value="GLOBAL"/>
        <details key="icon" value="pi pi-bolt"/>
      </eAnnotations>
    </eOperations>

    <eOperations name="connectServer">
      <eAnnotations source="http://gene/model/command/Command">
        <details key="commandId" value="jobs.connectServer"/>
        <details key="label" value="Connect Action Server"/>
        <details key="category" value="TOOLS"/>
        <details key="scope" value="GLOBAL"/>
        <details key="icon" value="pi pi-server"/>
      </eAnnotations>
      <eParameters name="url" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" lowerBound="1"/>
    </eOperations>

  </eClassifiers>
</ecore:EPackage>
