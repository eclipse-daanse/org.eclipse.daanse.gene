{
  "id": "storage-indexeddb",
  "name": "IndexedDB Storage Adapter",
  "version": "1.0.0",
  "description": "Browser-local storage using IndexedDB",
  "entry": "src/index.ts",
  "exports": {
    "./adapter": {
      "type": "adapter",
      "description": "IndexedDB storage adapter",
      "serviceId": "storage.adapter.indexeddb"
