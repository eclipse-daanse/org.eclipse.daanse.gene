{
  "name": "gene",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:plugins": "run-p dev plugins:watch",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:storage": "npm run test --workspaces --if-present",
    "build-only": "vite build",
    "build:prod": "run-s build-only plugins:build-all plugins:prepare",
    "plugins:prepare": "node scripts/prepare-plugins.js",
    "plugins:build-all": "node scripts/build-plugins.js",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "plugins:build": "npm run build:tsm --workspace=storage-core && npm run build:tsm --workspace=storage-indexeddb && npm run build:tsm --workspace=storage-git",
    "plugins:watch": "run-p plugins:watch:*",
    "plugins:watch:indexeddb": "npm run watch:tsm --workspace=storage-indexeddb",
    "plugins:watch:git": "npm run watch:tsm --workspace=storage-git",
    "generate": "emfts-codegen generate -m learn/fennec-generic-ui.ecore -c learn/fennec-generic-ui.genconfig -o src/generated/fennecui",
    "generate:storage": "npm run generate --workspace=storage-model"
  },
  "dependencies": {
    "@eclipse-daanse/org.eclipse.daanse.feel.langium": "^0.0.1-next.1",
    "@eclipse-daanse/org.eclipse.daanse.feel.lsp.worker": "^0.0.1-next.2",
    "@eclipse-daanse/tsm": "^0.0.1-next.2",
    "@emfts/codec.jsonschema": "^0.0.1-next.1",
    "@emfts/core": "^0.1.1-next.2",
    "@emfts/ocl.engine": "^0.0.1-next.1",
    "@emfts/ocl.langium": "^0.0.1-next.1",
    "@emfts/ocl.lsp.worker": "^0.0.1-next.2",
    "@emfts/ocl.model": "^0.0.1-next.1",
    "@emfts/vue-registry": "^0.0.1-next.1",
    "@faker-js/faker": "^9.9.0",
    "@primevue/themes": "^4.3.3",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "core": "*",
    "feelin": "^6.2.0",
    "instance-builder": "*",
    "monaco-editor": "^0.52.2",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.3",
    "reflect-metadata": "^0.2.2",
    "storage-core": "*",
    "storage-git": "*",
    "storage-indexeddb": "*",
    "storage-model": "*",
    "ui-file-explorer": "*",
    "ui-instance-tree": "*",
    "ui-layout": "*",
    "ui-model-browser": "*",
    "ui-model-view": "*",
    "ui-perspectives": "*",
    "ui-problems-panel": "*",
    "ui-properties-panel": "*",
    "ui-workspace": "*",
    "ui-xmi-viewer": "*",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@emfts/codegen": "^0.0.1-next.1",
    "@originjs/vite-plugin-federation": "^1.4.1",

    "@tsconfig/node24": "^24.0.3",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/eslint-plugin": "^1.6.5",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "~10.6.2",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "npm-run-all2": "^8.0.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.2"
  }
}
