    <eStructuralFeatures xsi:type="ecore:EAttribute" name="scope" eType="#//MappingScope" defaultValueLiteral="TYPE_ONLY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether rule applies to owner subtypes."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="containmentFeature" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional specific containment feature to sort. If empty, applies to all containments."/>
      </eAnnotations>
