<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore"
    name="fennecui"
    nsURI="https://eclipse.org/fennec/ts/generic/ui"
    nsPrefix="fennecui">

  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="documentation" value="Orthogonal configuration model for generic EMF editors. This model describes how a generic editor should discover resources, load metamodels, visualize objects (icons, labels, styles), handle reference selection with filtering, define storage locations for objects, and provide quick actions. It is independent of the actual domain model being edited."/>
  </eAnnotations>

  <!-- ============================================================
       ENUMERATIONS
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EEnum" name="PatternKind">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Kind of file pattern used for resource discovery."/>
    </eAnnotations>
    <eLiterals name="GLOB" value="0" literal="GLOB">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Glob pattern (e.g., **/*.xmi, *.ecore)."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="REGEX" value="1" literal="REGEX">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Regular expression pattern."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="SUFFIX" value="2" literal="SUFFIX">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="File suffix/extension (e.g., .xmi, .ecore)."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="PREFIX" value="3" literal="PREFIX">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="File name prefix."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="IconLibrary">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Known icon libraries for UI rendering."/>
    </eAnnotations>
    <eLiterals name="MATERIAL_SYMBOLS" value="0" literal="MATERIAL_SYMBOLS">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Google Material Symbols icon library."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="FONT_AWESOME" value="1" literal="FONT_AWESOME">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Font Awesome icon library."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="LUCIDE" value="2" literal="LUCIDE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Lucide icon library."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="CUSTOM" value="3" literal="CUSTOM">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Custom icon library defined by the implementation."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="LabelMode">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Strategy for computing object labels in the UI."/>
    </eAnnotations>
    <eLiterals name="ID" value="0" literal="ID">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Use the object's ID attribute as label."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="NAME" value="1" literal="NAME">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Use the object's name attribute as label."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="TEMPLATE" value="2" literal="TEMPLATE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Use a template pattern with placeholders for attributes."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="OCL" value="3" literal="OCL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Compute label using an OCL expression returning a String."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="MappingScope">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Scope for type-based rules: exact type or including subtypes."/>
    </eAnnotations>
    <eLiterals name="TYPE_ONLY" value="0" literal="TYPE_ONLY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Rule applies only to the exact specified type."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="TYPE_AND_SUBTYPES" value="1" literal="TYPE_AND_SUBTYPES">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Rule applies to the type and all its subtypes."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="FilterType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Type of tree view filter."/>
    </eAnnotations>
    <eLiterals name="ECLASS_TYPE" value="0" literal="ECLASS_TYPE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Filter based on EClass type (hides all instances of a type)."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="ELEMENT" value="1" literal="ELEMENT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Filter based on specific element URI."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="FontWeight">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Font weight for text styling."/>
    </eAnnotations>
    <eLiterals name="NORMAL" value="0" literal="NORMAL"/>
    <eLiterals name="BOLD" value="1" literal="BOLD"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="SortDirection">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Direction for sorting operations."/>
    </eAnnotations>
    <eLiterals name="ASC" value="0" literal="ASC">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Ascending order (A-Z, 0-9)."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="DESC" value="1" literal="DESC">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Descending order (Z-A, 9-0)."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="Visibility">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Visibility state for inspector features."/>
    </eAnnotations>
    <eLiterals name="DEFAULT" value="0" literal="DEFAULT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Use default visibility determined by the editor."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="VISIBLE" value="1" literal="VISIBLE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Force feature to be visible."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="HIDDEN" value="2" literal="HIDDEN">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Force feature to be hidden."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ActionScope">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Context where a quick action is available."/>
    </eAnnotations>
    <eLiterals name="OBJECT" value="0" literal="OBJECT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Action appears in object context menu."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="EDITOR" value="1" literal="EDITOR">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Action appears in editor-level menu."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="BOTH" value="2" literal="BOTH">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Action appears in both object and editor contexts."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ActionType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Classification of action purpose."/>
    </eAnnotations>
    <eLiterals name="QUERY" value="0" literal="QUERY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Query or retrieve data."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="VALIDATION" value="1" literal="VALIDATION">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Validate data and return messages."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="DOCUMENTATION" value="2" literal="DOCUMENTATION">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Generate documentation."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="TRANSFORMATION" value="3" literal="TRANSFORMATION">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Transform model data."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="CUSTOM" value="4" literal="CUSTOM">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Custom user-defined action."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="HttpMethod">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="HTTP method for remote action endpoints."/>
    </eAnnotations>
    <eLiterals name="GET" value="0" literal="GET"/>
    <eLiterals name="POST" value="1" literal="POST"/>
    <eLiterals name="PUT" value="2" literal="PUT"/>
    <eLiterals name="PATCH" value="3" literal="PATCH"/>
    <eLiterals name="DELETE" value="4" literal="DELETE"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="SerializationType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="How action input data is serialized for remote transport."/>
    </eAnnotations>
    <eLiterals name="QUERY_PARAMS" value="0" literal="QUERY_PARAMS">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Encode parameters in URL query string."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="JSON_BODY" value="1" literal="JSON_BODY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="JSON.stringify with content-type application/json."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="XMI_BODY" value="2" literal="XMI_BODY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Serialize EMF objects as XMI XML."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="MULTIPART" value="3" literal="MULTIPART">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="FormData with files and JSON parts."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="AuthType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Authentication method for remote action endpoints."/>
    </eAnnotations>
    <eLiterals name="NONE" value="0" literal="NONE"/>
    <eLiterals name="BASIC" value="1" literal="BASIC"/>
    <eLiterals name="BEARER" value="2" literal="BEARER"/>
    <eLiterals name="API_KEY" value="3" literal="API_KEY"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ExecutionMode">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Whether a remote action is executed synchronously or asynchronously."/>
    </eAnnotations>
    <eLiterals name="SYNC" value="0" literal="SYNC"/>
    <eLiterals name="ASYNC" value="1" literal="ASYNC"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ParameterType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Data type of an action parameter."/>
    </eAnnotations>
    <eLiterals name="STRING" value="0" literal="STRING"/>
    <eLiterals name="NUMBER" value="1" literal="NUMBER"/>
    <eLiterals name="BOOLEAN" value="2" literal="BOOLEAN"/>
    <eLiterals name="DATE" value="3" literal="DATE"/>
    <eLiterals name="ENUM" value="4" literal="ENUM"/>
    <eLiterals name="FILE" value="5" literal="FILE"/>
    <eLiterals name="ECLASS_REF" value="6" literal="ECLASS_REF"/>
    <eLiterals name="EOBJECT_REF" value="7" literal="EOBJECT_REF"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ReturnType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Type of artifact returned by an action."/>
    </eAnnotations>
    <eLiterals name="FILE" value="0" literal="FILE"/>
    <eLiterals name="VALIDATION_MESSAGES" value="1" literal="VALIDATION_MESSAGES"/>
    <eLiterals name="MARKDOWN" value="2" literal="MARKDOWN"/>
    <eLiterals name="XMI" value="3" literal="XMI"/>
    <eLiterals name="JSON" value="4" literal="JSON"/>
    <eLiterals name="HTML" value="5" literal="HTML"/>
    <eLiterals name="IMAGE" value="6" literal="IMAGE"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="FileHandling">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="How a file artifact should be handled after action execution."/>
    </eAnnotations>
    <eLiterals name="DOWNLOAD" value="0" literal="DOWNLOAD"/>
    <eLiterals name="WORKSPACE_SAVE" value="1" literal="WORKSPACE_SAVE"/>
    <eLiterals name="OPEN" value="2" literal="OPEN"/>
    <eLiterals name="AUTO" value="3" literal="AUTO"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="XmiImportMode">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="How XMI result artifacts are imported into the working resource set."/>
    </eAnnotations>
    <eLiterals name="NEW_RESOURCE" value="0" literal="NEW_RESOURCE"/>
    <eLiterals name="REPLACE_RESOURCE" value="1" literal="REPLACE_RESOURCE"/>
    <eLiterals name="MERGE_INTO_EXISTING" value="2" literal="MERGE_INTO_EXISTING"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ExecutionEnvironment">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Execution environment for internal action handlers."/>
    </eAnnotations>
    <eLiterals name="MAIN_THREAD" value="0" literal="MAIN_THREAD"/>
    <eLiterals name="WEB_WORKER" value="1" literal="WEB_WORKER"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="LifecycleEventType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Application lifecycle events that can trigger actions."/>
    </eAnnotations>
    <eLiterals name="WORKSPACE_OPENED" value="0" literal="WORKSPACE_OPENED"/>
    <eLiterals name="WORKSPACE_CLOSED" value="1" literal="WORKSPACE_CLOSED"/>
    <eLiterals name="PERSPECTIVE_CHANGED" value="2" literal="PERSPECTIVE_CHANGED"/>
    <eLiterals name="FILE_SAVED" value="3" literal="FILE_SAVED"/>
    <eLiterals name="FILE_OPENED" value="4" literal="FILE_OPENED"/>
    <eLiterals name="MODEL_LOADED" value="5" literal="MODEL_LOADED"/>
    <eLiterals name="MODEL_UNLOADED" value="6" literal="MODEL_UNLOADED"/>
    <eLiterals name="VALIDATION_COMPLETED" value="7" literal="VALIDATION_COMPLETED"/>
    <eLiterals name="EDITOR_ACTIVATED" value="8" literal="EDITOR_ACTIVATED"/>
    <eLiterals name="EDITOR_DEACTIVATED" value="9" literal="EDITOR_DEACTIVATED"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="DomainChangeType">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Type of domain model change that can trigger actions."/>
    </eAnnotations>
    <eLiterals name="CREATE" value="0" literal="CREATE"/>
    <eLiterals name="DELETE" value="1" literal="DELETE"/>
    <eLiterals name="SET" value="2" literal="SET"/>
    <eLiterals name="ADD" value="3" literal="ADD"/>
    <eLiterals name="REMOVE" value="4" literal="REMOVE"/>
    <eLiterals name="MOVE" value="5" literal="MOVE"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ExecuteMode">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="How multiple actions in an event mapping are executed."/>
    </eAnnotations>
    <eLiterals name="ALL" value="0" literal="ALL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Execute all mapped actions (parallel where possible)."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="FIRST_MATCH" value="1" literal="FIRST_MATCH">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Execute only the first action whose condition is true."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="SEQUENTIAL" value="2" literal="SEQUENTIAL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Execute actions sequentially, abort on failure."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ModelSourceKind">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Kind of model source for bootstrapping the editor's internal model factory."/>
    </eAnnotations>
    <eLiterals name="ECORE" value="0" literal="ECORE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Ecore metamodel file (.ecore)."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="GENMODEL" value="1" literal="GENMODEL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="EMF Generator model file (.genmodel)."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="XMI" value="2" literal="XMI">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="XMI model instance file."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="EMF_PACKAGE_CLASS" value="3" literal="EMF_PACKAGE_CLASS">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Java EPackage class to register programmatically."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="CUSTOM" value="4" literal="CUSTOM">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Custom model source type handled by the implementation."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="ResolutionStrategy">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Strategy for resolving relative paths and URIs."/>
    </eAnnotations>
    <eLiterals name="RELATIVE_TO_CONFIG" value="0" literal="RELATIVE_TO_CONFIG">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Resolve relative to the configuration file location."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="RELATIVE_TO_WORKSPACE" value="1" literal="RELATIVE_TO_WORKSPACE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Resolve relative to the workspace root."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="ABSOLUTE_OR_URI" value="2" literal="ABSOLUTE_OR_URI">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Use as absolute path or full URI."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EEnum" name="SelectionMode">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Mode for candidate selection when setting references."/>
    </eAnnotations>
    <eLiterals name="DEFAULT_ALL" value="0" literal="DEFAULT_ALL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Show all candidates by default unless filter applies."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="FILTERED_ONLY" value="1" literal="FILTERED_ONLY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Only show candidates that pass the filter expression."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <!-- ============================================================
       ROOT CONFIGURATION
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="EditorConfig">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Root configuration element for a generic EMF editor. Contains all rules and settings for resource discovery, visualization, and editor behavior."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="id" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional unique identifier for this configuration."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Human-readable name of this configuration."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="description" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Description of this configuration's purpose."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="configFileExtensions" upperBound="-1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="File extensions that identify configuration files for this editor (e.g., 'fennecui', 'gecfg.xmi')."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="enabled" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
