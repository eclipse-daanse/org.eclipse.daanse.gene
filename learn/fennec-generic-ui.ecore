  <!-- ============================================================
       ACTIONS
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="AbstractAction" abstract="true">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Base class for all configurable actions. Actions can appear in context menus, toolbars, or be triggered by events. Subclasses define whether the action is executed locally (InternalAction) or via HTTP (RemoteAction)."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="actionId" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Unique action identifier. Used for registry lookup and event mapping references."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="label" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Display label in menus and toolbar."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="description" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Human-readable description shown as tooltip."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="icon" eType="#//IconSpec" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional icon for the action."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="actionType" eType="#//ActionType" defaultValueLiteral="CUSTOM">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Classification of action purpose (QUERY, VALIDATION, DOCUMENTATION, TRANSFORMATION, CUSTOM)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="actionScope" eType="#//ActionScope" defaultValueLiteral="OBJECT">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Context where this action appears (OBJECT context menu, EDITOR menu, or BOTH)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="targetTypeUri" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional EClass URI restriction. If set, action is only available for objects of this type. Format: nsURI#//ClassName."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="targetScope" eType="#//MappingScope" defaultValueLiteral="TYPE_AND_SUBTYPES">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether type restriction includes subtypes."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="perspectiveIds" upperBound="-1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Perspective IDs where this action is available. Empty list means all perspectives."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="availableWhen" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="OCL expression evaluated against the selected object. Action is visible only if expression returns true."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="enabledWhen" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="OCL expression for enablement. Action is shown but greyed out if expression returns false."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="order" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="0">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Display order in the menu (lower = higher)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="enabled" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Global on/off toggle for this action."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="inputSpec" eType="#//InputSpecification" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Specification of how input data is collected for this action."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="parameters" upperBound="-1" eType="#//ActionParameter" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Configurable parameters shown in a dialog before execution."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="returnTypes" upperBound="-1" eType="#//ReturnType">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Expected return artifact types. Determines which result handlers are used."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- QuickAction kept for backwards compatibility — maps to InternalAction semantics -->
  <eClassifiers xsi:type="ecore:EClass" name="QuickAction" eSuperTypes="#//AbstractAction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Simplified action for backwards compatibility. Use InternalAction or RemoteAction for new configurations."/>
    </eAnnotations>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="InternalAction" eSuperTypes="#//AbstractAction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Action executed by a local TypeScript handler. The handler is identified by handlerId and registered by a TSM plugin module."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="handlerId" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Reference to a registered handler in the InternalExecutor's HandlerRegistry."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="executionEnvironment" eType="#//ExecutionEnvironment" defaultValueLiteral="MAIN_THREAD">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether the handler runs on the main thread or in a Web Worker sandbox."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="timeoutMs" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="30000">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Maximum execution time in milliseconds."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="RemoteAction" eSuperTypes="#//AbstractAction">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Action executed via HTTP request to a remote service endpoint. Supports sync and async execution modes, configurable serialization, authentication, and retry logic."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="endpointUrl" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Target URL. Supports template variables: {objectId}, {className}, {nsUri}, {perspectiveId}."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="httpMethod" eType="#//HttpMethod" defaultValueLiteral="POST">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="HTTP method for the request."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="serialization" eType="#//SerializationType" defaultValueLiteral="JSON_BODY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="How input data is serialized for transport."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="contentType" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="application/json">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Content-Type header for the request."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="authConfig" eType="#//AuthConfiguration" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Authentication configuration. Credentials are never stored here — only references."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="connectionTimeoutMs" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="10000">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Connection timeout in milliseconds."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="readTimeoutMs" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="30000">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Read timeout in milliseconds."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="retryConfig" eType="#//RetryConfiguration" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Retry configuration for failed requests."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="executionMode" eType="#//ExecutionMode" defaultValueLiteral="SYNC">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether the action is synchronous (wait for response) or asynchronous (poll for result)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="asyncConfig" eType="#//AsyncConfiguration" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Configuration for async execution. Only used when executionMode=ASYNC."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="responseMapping" eType="#//ResponseMapping" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="How the HTTP response is mapped to ActionResult artifacts."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- ============================================================
       ACTION SUPPORT CLASSES
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="ActionParameter">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Definition of a user-configurable action parameter. Rendered as a form field in the parameter dialog before action execution."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Parameter name (used as key in the parameters map)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="displayName" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Human-readable label for the form field."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="description" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Help text shown below the form field."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="type" eType="#//ParameterType" defaultValueLiteral="STRING">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Data type determining the UI widget (InputText, InputNumber, Checkbox, Dropdown, etc.)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="required" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="false">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether this parameter must be provided before execution."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="defaultValue" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Default value (as string, converted according to type)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="enumValues" upperBound="-1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Allowed values when type=ENUM. Rendered as dropdown."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="validationExpression" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="OCL expression for parameter validation. Evaluated with the parameter value as context."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="InputSpecification">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Specifies how input data is collected for action execution. Controls which objects and schema information are passed to the executor."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="includeSelection" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether the currently selected object is included as primary input."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="includeSchema" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="false">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether the EPackage/metamodel is included in the input."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="schemaScope" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="REFERENCED">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Scope of schema inclusion: FULL (entire EPackage) or REFERENCED (only referenced classes)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="oclFilters" upperBound="-1" eType="#//OclFilter" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="OCL expressions to select additional objects as input."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="OclFilter">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="OCL expression used to select additional objects for action input collection."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="expression" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="OCL expression to evaluate. Returns a collection of EObjects."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="scope" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="RESOURCE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Evaluation scope: RESOURCE (single resource), RESOURCE_SET (all resources), PACKAGE (EPackage)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="alias" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional alias name for referencing the selected objects in the action context."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="AuthConfiguration">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Authentication configuration for remote actions. Credentials are never stored directly — only references to a credential store."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="authType" eType="#//AuthType" defaultValueLiteral="NONE">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Authentication method."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="credentialRef" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Reference to credentials in the workspace credential store."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="tokenEndpoint" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Token exchange endpoint (for OAuth2)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="apiKeyHeader" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="X-API-Key">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Custom header name for API key authentication."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="RetryConfiguration">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Retry configuration for failed remote action requests."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="maxRetries" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="3"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="retryDelayMs" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="1000"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="backoffMultiplier" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble" defaultValueLiteral="2.0"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="retryOnStatus" upperBound="-1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="HTTP status codes that trigger a retry (e.g., 502, 503, 504)."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="AsyncConfiguration">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Configuration for asynchronous remote action execution. Defines how to poll for status and retrieve results."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="statusEndpoint" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="URL to poll for job status. Supports {jobId} template variable."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="resultEndpoint" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="URL to retrieve results after job completion."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="cancelEndpoint" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="URL to cancel a running job."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="pollIntervalMs" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="2000"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="maxPollAttempts" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="150"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="timeoutMs" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="300000"/>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="ResponseMapping">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Mapping rules for extracting action results from HTTP responses. Uses JSONPath expressions."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="statusPath" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="JSONPath to the status field in the response."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="dataPath" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="JSONPath to the data field in the response."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="errorPath" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="JSONPath to the error field in the response."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="artifactMappings" upperBound="-1" eType="#//ArtifactMapping" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Mapping of response data to result artifacts."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="ArtifactMapping">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Maps a part of the HTTP response to an action result artifact."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="returnType" eType="#//ReturnType"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="sourcePath" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="JSONPath or header name to extract the artifact data from."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="fileHandling" eType="#//FileHandling" defaultValueLiteral="AUTO"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="xmiImportMode" eType="#//XmiImportMode" defaultValueLiteral="NEW_RESOURCE"/>
  </eClassifiers>

  <!-- ============================================================
       EVENTS & EVENT-ACTION MAPPINGS
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="EventActionMapping">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Declarative mapping from an event to one or more actions. When the specified event occurs and the condition is met, the referenced actions are executed. Enables event-driven automation without code."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Human-readable name for this mapping."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="description" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Description of what this mapping does."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="enabled" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether this mapping is active."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="order" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="0">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Evaluation order when multiple mappings match the same event."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="event" eType="#//EventSpec" containment="true" lowerBound="1">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="The event that triggers this mapping."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="condition" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="OCL expression evaluated against the event context. Mapping fires only if expression returns true."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="actionRefs" upperBound="-1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" lowerBound="1">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Action IDs to execute when the event fires. Looked up in the ActionRegistry."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="parameterOverrides" upperBound="-1" eType="#//ParameterOverride" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Parameter value overrides passed to the action. Allows event context data to flow into action parameters."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="debounceMs" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="0">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Debounce time in milliseconds. If the same event fires again within this window, the previous execution is cancelled."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="executeMode" eType="#//ExecuteMode" defaultValueLiteral="ALL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="How multiple actions are executed: ALL (parallel), FIRST_MATCH (first with true condition), SEQUENTIAL (in order, abort on failure)."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="ParameterOverride">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Overrides an action parameter value in the context of an event-action mapping. The value can be a literal or an OCL expression evaluated against the event context."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="parameterName" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Name of the action parameter to override."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="valueExpression" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Value expression. Can be a literal string or an OCL expression (prefixed with 'ocl:') evaluated against the event context object."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- Event Specification Hierarchy -->

  <eClassifiers xsi:type="ecore:EClass" name="EventSpec" abstract="true">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Abstract base for event specifications. Subclasses define the type of event (lifecycle, domain change, or custom plugin event)."/>
    </eAnnotations>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="LifecycleEvent" eSuperTypes="#//EventSpec">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Application lifecycle event (workspace opened, perspective changed, file saved, etc.)."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="eventType" eType="#//LifecycleEventType">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="The specific lifecycle event."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="DomainEvent" eSuperTypes="#//EventSpec">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Domain model change event based on EMF notifications. Fires when objects are created, modified, or deleted."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="changeType" eType="#//DomainChangeType">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="The type of model change (CREATE, DELETE, SET, ADD, REMOVE, MOVE)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="featureName" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional feature name filter. If set, only changes to this specific feature trigger the event. If empty, any change on the target type triggers."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="targetTypeUri" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional type restriction. If set, only changes on objects of this EClass trigger the event."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="targetScope" eType="#//MappingScope" defaultValueLiteral="TYPE_AND_SUBTYPES">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether the type restriction includes subtypes."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="CustomEvent" eSuperTypes="#//EventSpec">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Custom event emitted by a plugin module via the EventBus. Allows plugins to define their own event types."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="eventId" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Custom event identifier (e.g., 'atlas.schema.published', 'cocl.validation.done')."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="sourceModuleId" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional filter: only match events from this TSM module."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- ============================================================
       REFERENCE SELECTION
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="ReferenceSelectionRule">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Rule for filtering and presenting candidates when setting a reference. Allows constraining available options based on context (e.g., only show columns from the selected table)."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="ownerTypeUri" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="URI of the owner type containing the reference being set."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="ownerScope" eType="#//MappingScope" defaultValueLiteral="TYPE_ONLY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether owner type match includes subtypes."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="referenceFeature" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Name of the EReference feature for which candidates are filtered."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="mode" eType="#//SelectionMode" defaultValueLiteral="DEFAULT_ALL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Selection mode: show all or only filtered candidates."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="condition" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Condition expression for when this rule applies (evaluated on owner object)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="priority" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="0">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Priority for conflict resolution (higher wins)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="enabled" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether this rule is active."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="filter" eType="#//CandidateFilter" containment="true" lowerBound="1">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Filter definition for candidates."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="presentation" eType="#//CandidatePresentation" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional presentation overrides for the candidate picker."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="CandidateFilter">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Filter for reference selection candidates. Filter expression is evaluated for each candidate object."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="filterExpression" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Expression (OCL) returning Boolean. Context is candidate object. Use 'owner' variable for the edited object."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="language" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="OCL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Expression language identifier."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="explanation" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="User-visible explanation of why candidates are filtered."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="CandidatePresentation">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Presentation options for candidates in reference selection picker."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="labelExpression" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Expression for computing candidate labels in the picker."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="language" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="OCL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Expression language identifier."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="sortKeys" upperBound="-1" eType="#//SortKey" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional sort keys for ordering candidates in the picker."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- ============================================================
       STORAGE LOCATION RULES (NEW)
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="StorageLocationRule">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Rule defining where objects of a specific type should be stored (folder/subfolder structure). This enables automatic organization of model files by type."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="targetTypeUri" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="URI of the EClass for which this storage rule applies."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="scope" eType="#//MappingScope" defaultValueLiteral="TYPE_ONLY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether rule applies to subtypes."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="folderPath" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Relative folder path where objects of this type should be stored (e.g., 'entities', 'schemas/tables'). May contain ${placeholder} patterns."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="fileNamePattern" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Pattern for generating file names (e.g., '${name}.entity.xmi'). May contain ${placeholder} patterns."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="createFolder" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether to automatically create the folder if it does not exist."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="separateFile" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="false">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether each object should be stored in a separate file (fragment storage)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="condition" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional condition expression for when this rule applies."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="priority" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="0">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Priority for conflict resolution (higher wins)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="enabled" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether this rule is active."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="pathBindings" upperBound="-1" eType="#//AttributeBinding" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Bindings for placeholders in folderPath and fileNamePattern."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- ============================================================
       NAMESPACE MAPPING
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="NamespaceMapping">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Mapping from namespace URI to package registration information."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nsUri" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Namespace URI to map."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="packageClass" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Fully qualified Java class name of the EPackage."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="genModelUri" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional GenModel URI for the package."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- ============================================================
       LAYOUT CONFIGURATION
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="LayoutConfig">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Layout configuration for the editor workspace. Stores panel sizes and visibility settings."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="primarySidebarWidth" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="260">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Width of the primary (left) sidebar in pixels."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="secondarySidebarWidth" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="300">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Width of the secondary (right) sidebar in pixels."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="panelAreaHeight" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="200">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Height of the bottom panel area in pixels."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="primarySidebarVisible" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether the primary sidebar is visible."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="secondarySidebarVisible" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether the secondary sidebar is visible."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="panelAreaVisible" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="false">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether the bottom panel area is visible."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="activityBarVisible" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether the activity bar is visible."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="statusBarVisible" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether the status bar is visible."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="activeActivityId" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="ID of the currently active activity in the activity bar."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="panelPositions" upperBound="-1" eType="#//PanelPosition" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Custom panel positions that override default locations."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- Panel Position - maps panel ID to location -->
  <eClassifiers xsi:type="ecore:EClass" name="PanelPosition">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Defines the position of a panel in the layout."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="panelId" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Unique identifier of the panel."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="location" eType="#//PanelLocation" defaultValueLiteral="PRIMARY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Location where the panel should be displayed."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="order" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="0">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Display order within the location (lower values appear first)."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- Panel Location Enum -->
  <eClassifiers xsi:type="ecore:EEnum" name="PanelLocation">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Available locations for panels in the layout."/>
    </eAnnotations>
    <eLiterals name="PRIMARY" value="0">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Primary (left) sidebar."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="SECONDARY" value="1">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Secondary (right) sidebar."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="BOTTOM" value="2">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Bottom panel area."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <!-- ============================================================
       UI DEFAULTS
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="UiDefaults">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Default UI settings and fallback values."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="defaultLabelMode" eType="#//LabelMode" defaultValueLiteral="NAME">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Default label mode when no rule matches."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="showQualifiedNames" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="false">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether to prefer qualified names in displays."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="unknownTypeLabel" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="&lt;unnamed&gt;">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Fallback label for objects without a computable label."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="unknownTypeIcon" eType="#//Utf8Icon" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Fallback icon for types without an icon mapping."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- ============================================================
       TREE VIEWS (FILTERS)
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="TreeView">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="A named collection of filters for hiding elements in the tree views."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="id" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Unique identifier for this view."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Human-readable name of the view."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="description" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional description of what this view shows."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="enabled" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether this view is active."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="filters" upperBound="-1" eType="#//TreeFilter" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Filters that define what to hide in this view."/>
      </eAnnotations>
    </eStructuralFeatures>

    <!-- Perspective Configuration -->
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="showInActivityBar" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="false">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether this view should appear as a perspective in the Activity Bar."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="perspectiveIcon" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Icon class for the Activity Bar (e.g., 'pi pi-filter')."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="perspectiveOrder" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="100">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Order position in the Activity Bar (lower values appear first)."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="TreeFilter">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="A single filter rule for hiding elements in tree views."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="filterType" eType="#//FilterType">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Type of filter: by EClass type or by specific element."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="targetTypeUri" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="For ECLASS_TYPE filters: the nsURI#//ClassName of the type to hide."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="scope" eType="#//MappingScope" defaultValueLiteral="TYPE_ONLY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="For ECLASS_TYPE filters: whether to include subtypes."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="elementUri" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="For ELEMENT filters: the URI fragment of the specific element to hide."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="hidden" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether this filter is active (elements matching are hidden)."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- ============================================================
       PACKAGE RESOLVER
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EEnum" name="PackageResolverKind">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Kind of package resolver for cascaded EPackage resolution."/>
    </eAnnotations>
    <eLiterals name="LOCAL" value="0" literal="LOCAL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Resolve from local EPackageRegistry."/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="MODEL_ATLAS" value="1" literal="MODEL_ATLAS">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Resolve from Model Atlas server."/>
      </eAnnotations>
    </eLiterals>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="PackageResolverChain">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Ordered chain of package resolvers for cascaded EPackage resolution. Resolvers are tried in order until a package is found."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="autoResolveReferences" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether to automatically resolve cross-package proxy references after loading."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="maxResolutionDepth" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt" defaultValueLiteral="-1">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Maximum depth for transitive dependency resolution. -1 means unlimited."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EReference" name="resolvers" upperBound="-1" eType="#//PackageResolver" containment="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Ordered list of package resolvers. Tried in order until a package is found."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <eClassifiers xsi:type="ecore:EClass" name="PackageResolver">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="A single package resolver in the resolution chain. Can resolve packages from local registry or Model Atlas server."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Human-readable name for this resolver."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="kind" eType="#//PackageResolverKind">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Type of resolver (LOCAL or MODEL_ATLAS)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="enabled" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether this resolver is active."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="baseUrl" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Base URL of the Model Atlas REST API (for MODEL_ATLAS kind)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="scopeName" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Scope name in Model Atlas (for MODEL_ATLAS kind)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="stage" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString" defaultValueLiteral="release">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Stage in Model Atlas (for MODEL_ATLAS kind). Defaults to 'release'."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="token" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional authentication token for Model Atlas."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- ============================================================
       ATLAS CONNECTION
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="AtlasConnection">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Configuration for a Model Atlas server connection. Stored in the workspace to auto-connect on open."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="name" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Display name for this connection."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="baseUrl" lowerBound="1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Base URL of the Model Atlas REST API (e.g. http://localhost:8086/atlas/rest)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="scopeName" lowerBound="1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Name of the scope to connect to (e.g. jena)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="token" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional authentication token."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="autoConnect" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether to automatically connect when the workspace is opened."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="enabled" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean" defaultValueLiteral="true">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Whether this connection is active."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

  <!-- ============================================================
       CUSTOM ICON DEFINITION
       ============================================================ -->

  <eClassifiers xsi:type="ecore:EClass" name="CustomIconDefinition">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="A user-defined custom icon. May be an inline SVG/PNG (dataUrl) or reference an external library URL."/>
    </eAnnotations>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="id" lowerBound="1" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Unique identifier for this custom icon (used in icon mappings)."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="label" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Human-readable display name shown in the IconPicker."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="category" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Optional category for grouping in the IconPicker (e.g. 'custom', 'project')."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="dataUrl" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Inline data URL (base64-encoded SVG/PNG) or external URL to an icon/sprite sheet."/>
      </eAnnotations>
    </eStructuralFeatures>

    <eStructuralFeatures xsi:type="ecore:EAttribute" name="keywords" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Space-separated search keywords for this icon."/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>

</ecore:EPackage>
